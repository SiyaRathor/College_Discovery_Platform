generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  questions Question[]
  answers   Answer[]
}

model College {
  id           Int     @id @default(autoincrement())
  name         String
  city         String
  state        String
  location     String
  type         String
  stream       String
  fees         Int
  rating       Float   @default(0)
  totalReviews Int     @default(0)
  naacGrade    String?
  nirfRank     Int?

  courses    Course[]
  placements Placement[]
  exams      CollegeExam[]
  questions  Question[]
}

model Course {
  id        Int     @id @default(autoincrement())
  name      String
  duration  String
  totalFees Int
  collegeId Int
  college   College @relation(fields: [collegeId], references: [id])
}

model Placement {
  id             Int     @id @default(autoincrement())
  year           Int
  averagePackage Int
  highestPackage Int
  placementRate  Int
  topRecruiters  String
  collegeId      Int
  college        College @relation(fields: [collegeId], references: [id])
}

model CollegeExam {
  id          Int     @id @default(autoincrement())
  examName    String
  cutoffRank  Int
  closingRank Int
  collegeId   Int
  college     College @relation(fields: [collegeId], references: [id])

  @@index([examName, closingRank])
}

model Question {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  createdAt DateTime @default(now())
  userId    Int
  collegeId Int?

  user    User     @relation(fields: [userId], references: [id])
  college College? @relation(fields: [collegeId], references: [id])
  answers Answer[]
}

model Answer {
  id         Int      @id @default(autoincrement())
  body       String
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())
  userId     Int
  questionId Int

  user     User     @relation(fields: [userId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}